              </constraints>
              <rules>
                <rule id="d09b-3aaa-3c6e-3a22" name="•Orbital Dominance" publicationId="a53b-cebe-de49-bcbc" hidden="false">
                  <description>During your activation, select one LIGHT SUPPORT or HEAVY SUPPORT ship. If that ship remains on a planetary objective at the end of the round, you gain +2 Victory Points. Play this card at the start of the unit&apos;s activation, and discard it at the end of the round.</description>
                </rule>
              </rules>
              <costs>
                <cost name="Command Points" typeId="c8f4-e049-f551-b319" value="1.0"/>
                <cost name="Resource Points" typeId="ba8e-c9ca-122e-08da" value="0.0"/>
