              <constraints>
                <constraint field="selections" scope="parent" value="2.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="05a0-7842-921e-b97a" type="max"/>
              </constraints>
              <rules>
                <rule id="7784-ae01-19c3-4986" name="•Unity of Purpose" publicationId="a53b-cebe-de49-bcbc" hidden="false">
                  <description>Select a ship or squadron within the Voice of Command range of your Task Force Commander. The chosen unit may reroll any failed Leadership or Nerve checks during this turn. Discard this card after it is used.</description>
                </rule>
              </rules>
              <costs>
                <cost name="Command Points" typeId="c8f4-e049-f551-b319" value="1.0"/>
