              </constraints>
              <rules>
                <rule id="2121-f40a-f7be-9905" name="••Logistical Superiority" publicationId="a53b-cebe-de49-bcbc" hidden="false">
                  <description>At the start of the Activation Phase, restore 1 health box to each of up to two friendly LIGHT CORE units within the Voice of Command range of your Task Force Commander.</description>
