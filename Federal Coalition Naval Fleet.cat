              </constraints>
              <rules>
                <rule id="536e-ee25-d736-cad3" name="•• Ironclad Resolve (Mobile Bay)" hidden="false">
                  <description>Play this card when MOBILE BAY is targeted by an attack. Reduce the total DMG by 3 for this attack. Discard this card after use.</description>
                </rule>
