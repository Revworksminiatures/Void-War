      <rules>
        <rule id="49dc-e84c-d901-b4d3" name="Boarding Clamps" publicationId="a53b-cebe-de49-bcbc" hidden="false">
          <description>A unit equipped with Boarding Clamps can make a Melee Attack against a target ship. If the attack is successful, the target ship is considered boarded. This action does not deal damage to the target but counts as one of the unit&apos;s actions for the turn.</description>
        </rule>
      </rules>
